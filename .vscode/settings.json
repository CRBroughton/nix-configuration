{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"/home/craig/nix-configuration\").inputs.nixpkgs { }"
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"/home/craig/nix-configuration\").nixosConfigurations.laptop.options"
        },
        "nixos-server": {
          "expr": "(builtins.getFlake \"/home/craig/nix-configuration\").nixosConfigurations.nixos-server.options"
        },
        "home-manager": {
          "expr": "(builtins.getFlake \"/home/craig/nix-configuration\").nixosConfigurations.laptop.options.home-manager.users.type.getSubOptions []"
        }
      },
      "formatting": {
        "command": [ "nixfmt" ]
      }
    }
  },
  "editor.formatOnSave": false,
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.nix$",
        "cmd": "nix-format"
      }
    ]
  }
}